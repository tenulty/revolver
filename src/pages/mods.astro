---

<Layout>
	<div class="flex flex-col items-center justify-center px-3 py-8">
		<h1 class="block pb-3 text-center text-3xl leading-8 sm:text-4xl">
			&#9935; Install Client-only Mods
		</h1>
		<p
			class="mb-7 text-center text-xl leading-5 text-[rgba(255,255,255,0.5)] sm:text-2xl"
		>
			Forge version 1.20.1, these are all required for joining.
		</p>

		<MinecraftButton
			id="return"
			href="/"
			label="Return to Menu"
			image={{
				src: "/media/return-to-menu.webp",
				alt: "Minecraft return button",
				width: 540,
				height: 55,
			}}
		/>
	</div>

	<div class="bg-[rgba(0,0,0,0.4)] py-10">
		<Modlist mods={mods} />
	</div>
</Layout>
